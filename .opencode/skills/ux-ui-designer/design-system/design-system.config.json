{
  "$comment": "Design system configuration for SAN.ai. Component library: shadcn/ui (new-york style, neutral base). The LLM reads this to generate consistent, on-brand code.",

  "theme": {
    "name": "san-ai",
    "mode": "light",
    "primaryColor": "neutral",
    "accentColor": "neutral",
    "neutralColor": "neutral",
    "errorColor": "destructive",
    "warningColor": "yellow",
    "successColor": "green",
    "infoColor": "blue",

    "radius": "lg",
    "radiusBase": "0.625rem",
    "density": "comfortable",

    "fontFamilySans": "Geist Sans",
    "fontFamilyMono": "Geist Mono",
    "typeScale": "majorThird"
  },

  "componentLibrary": {
    "name": "shadcn-ui",
    "style": "new-york",
    "baseColor": "neutral",
    "cssVariables": true,
    "componentsPath": "@/components/ui",
    "utilsPath": "@/lib/utils",
    "addCommand": "cd web && pnpm shadcn add <component-name>",
    "rules": [
      "NEVER hand-edit files in components/ui/ — always use `pnpm shadcn add` to add or update them",
      "Always import Form from @/components/ui/form (shadcn wrapper), NOT from react-hook-form",
      "Import cn() from @/lib/utils",
      "All installed components live in web/components/ui/"
    ],
    "installedComponents": [
      "accordion", "alert", "alert-dialog", "aspect-ratio", "avatar",
      "badge", "breadcrumb", "button", "button-group", "calendar",
      "card", "carousel", "chart", "checkbox", "collapsible",
      "command", "context-menu", "dialog", "drawer", "dropdown-menu",
      "empty", "field", "form", "hover-card", "input", "input-otp",
      "item", "kbd", "label", "menubar", "navigation-menu", "pagination",
      "popover", "progress", "radio-group", "resizable", "scroll-area",
      "select", "separator", "sheet", "sidebar", "skeleton", "slider",
      "sonner", "spinner", "switch", "table", "tabs", "textarea",
      "toggle", "toggle-group", "tooltip"
    ]
  },

  "components": {
    "button": {
      "defaultVariant": "default",
      "defaultSize": "default",
      "rounded": false,
      "fullWidthOnMobile": true
    },
    "input": {
      "defaultVariant": "outline",
      "defaultSize": "default",
      "floatingLabel": false
    },
    "card": {
      "defaultShadow": "sm",
      "defaultRadius": "lg",
      "defaultPadding": "lg"
    },
    "dialog": {
      "closeOnBackdrop": true,
      "defaultSize": "md"
    },
    "toast": {
      "library": "sonner",
      "position": "bottom-right",
      "duration": 4000
    }
  },

  "framework": {
    "name": "nextjs-shadcn",
    "nextjsVersion": "16",
    "tailwindVersion": "4",
    "reactVersion": "19",
    "typescript": true,
    "strictMode": true,
    "cssVariables": true,
    "componentVariants": "cva",
    "iconLibrary": "lucide-react",
    "iconImportRule": "Always alias lucide-react icons with an Icon suffix: `import { Bell as BellIcon } from 'lucide-react'`. Exception: DynamicIcon from lucide-react/dynamic.",
    "animationLibrary": "tw-animate-css",
    "stateManagement": "zustand",
    "formLibrary": "react-hook-form + zod",
    "httpClient": "axios",
    "packageManager": "pnpm"
  },

  "accessibility": {
    "wcagLevel": "AA",
    "focusRing": true,
    "reduceMotion": true,
    "forcedColors": false,
    "minimumContrastRatio": 4.5
  },

  "darkMode": {
    "enabled": true,
    "strategy": "class",
    "defaultMode": "system",
    "cssVariant": "@custom-variant dark (&:is(.dark *))"
  }
}
