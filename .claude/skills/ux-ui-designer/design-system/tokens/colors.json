{
  "$schema": "https://tr.designtokens.org/format/",
  "$description": "shadcn/ui CSS variable color system. Colors are defined as oklch values in globals.css and mapped to Tailwind utility classes via @theme inline. Use semantic token names (bg-primary, text-foreground, etc.) in components — never hardcode oklch values.",

  "cssVariableSource": "web/styles/globals.css",
  "tailwindMapping": "@theme inline block in globals.css maps --color-* to Tailwind utilities",

  "semantic": {
    "$description": "CSS variable names from :root in globals.css. Reference as Tailwind classes: bg-background, text-foreground, bg-primary, etc.",

    "background":    { "cssVar": "--background",    "tailwind": "bg-background / text-background",     "lightOklch": "oklch(1 0 0)",         "darkOklch": "oklch(0.145 0 0)" },
    "foreground":    { "cssVar": "--foreground",     "tailwind": "text-foreground",                      "lightOklch": "oklch(0.145 0 0)",      "darkOklch": "oklch(0.985 0 0)" },

    "card":          { "cssVar": "--card",           "tailwind": "bg-card",                              "lightOklch": "oklch(1 0 0)",         "darkOklch": "oklch(0.205 0 0)" },
    "cardForeground":{ "cssVar": "--card-foreground","tailwind": "text-card-foreground",                 "lightOklch": "oklch(0.145 0 0)",      "darkOklch": "oklch(0.985 0 0)" },

    "popover":       { "cssVar": "--popover",        "tailwind": "bg-popover",                           "lightOklch": "oklch(1 0 0)",         "darkOklch": "oklch(0.205 0 0)" },
    "popoverForeground": { "cssVar": "--popover-foreground", "tailwind": "text-popover-foreground",      "lightOklch": "oklch(0.145 0 0)",      "darkOklch": "oklch(0.985 0 0)" },

    "primary":       { "cssVar": "--primary",        "tailwind": "bg-primary",                           "lightOklch": "oklch(0.205 0 0)",      "darkOklch": "oklch(0.922 0 0)" },
    "primaryForeground": { "cssVar": "--primary-foreground", "tailwind": "text-primary-foreground",      "lightOklch": "oklch(0.985 0 0)",      "darkOklch": "oklch(0.205 0 0)" },

    "secondary":     { "cssVar": "--secondary",      "tailwind": "bg-secondary",                         "lightOklch": "oklch(0.97 0 0)",       "darkOklch": "oklch(0.269 0 0)" },
    "secondaryForeground": { "cssVar": "--secondary-foreground", "tailwind": "text-secondary-foreground","lightOklch": "oklch(0.205 0 0)",      "darkOklch": "oklch(0.985 0 0)" },

    "muted":         { "cssVar": "--muted",          "tailwind": "bg-muted",                             "lightOklch": "oklch(0.97 0 0)",       "darkOklch": "oklch(0.269 0 0)" },
    "mutedForeground": { "cssVar": "--muted-foreground", "tailwind": "text-muted-foreground",            "lightOklch": "oklch(0.556 0 0)",      "darkOklch": "oklch(0.708 0 0)" },

    "accent":        { "cssVar": "--accent",         "tailwind": "bg-accent",                            "lightOklch": "oklch(0.97 0 0)",       "darkOklch": "oklch(0.269 0 0)" },
    "accentForeground": { "cssVar": "--accent-foreground", "tailwind": "text-accent-foreground",         "lightOklch": "oklch(0.205 0 0)",      "darkOklch": "oklch(0.985 0 0)" },

    "destructive":   { "cssVar": "--destructive",    "tailwind": "bg-destructive / text-destructive",    "lightOklch": "oklch(0.577 0.245 27.325)", "darkOklch": "oklch(0.704 0.191 22.216)" },

    "border":        { "cssVar": "--border",         "tailwind": "border-border",                        "lightOklch": "oklch(0.922 0 0)",      "darkOklch": "oklch(1 0 0 / 10%)" },
    "input":         { "cssVar": "--input",          "tailwind": "border-input",                         "lightOklch": "oklch(0.922 0 0)",      "darkOklch": "oklch(1 0 0 / 15%)" },
    "ring":          { "cssVar": "--ring",           "tailwind": "ring-ring",                            "lightOklch": "oklch(0.708 0 0)",      "darkOklch": "oklch(0.556 0 0)" }
  },

  "sidebar": {
    "$description": "Sidebar-specific tokens for the AppSidebar component.",
    "sidebar":              { "cssVar": "--sidebar",                   "tailwind": "bg-sidebar" },
    "sidebarForeground":    { "cssVar": "--sidebar-foreground",        "tailwind": "text-sidebar-foreground" },
    "sidebarPrimary":       { "cssVar": "--sidebar-primary",          "tailwind": "bg-sidebar-primary" },
    "sidebarPrimaryFg":     { "cssVar": "--sidebar-primary-foreground","tailwind": "text-sidebar-primary-foreground" },
    "sidebarAccent":        { "cssVar": "--sidebar-accent",           "tailwind": "bg-sidebar-accent" },
    "sidebarAccentFg":      { "cssVar": "--sidebar-accent-foreground", "tailwind": "text-sidebar-accent-foreground" },
    "sidebarBorder":        { "cssVar": "--sidebar-border",           "tailwind": "border-sidebar-border" },
    "sidebarRing":          { "cssVar": "--sidebar-ring",             "tailwind": "ring-sidebar-ring" }
  },

  "chart": {
    "$description": "Chart color palette for recharts/chart.tsx",
    "chart1": { "cssVar": "--chart-1", "tailwind": "text-chart-1" },
    "chart2": { "cssVar": "--chart-2", "tailwind": "text-chart-2" },
    "chart3": { "cssVar": "--chart-3", "tailwind": "text-chart-3" },
    "chart4": { "cssVar": "--chart-4", "tailwind": "text-chart-4" },
    "chart5": { "cssVar": "--chart-5", "tailwind": "text-chart-5" }
  },

  "radius": {
    "$description": "Radius CSS variables. Base --radius is 0.625rem. Computed variants are in @theme inline.",
    "base":  { "cssVar": "--radius",    "value": "0.625rem" },
    "sm":    { "cssVar": "--radius-sm", "computed": "calc(var(--radius) - 4px)", "approx": "0.375rem" },
    "md":    { "cssVar": "--radius-md", "computed": "calc(var(--radius) - 2px)", "approx": "0.5rem"   },
    "lg":    { "cssVar": "--radius-lg", "computed": "var(--radius)",             "approx": "0.625rem" },
    "xl":    { "cssVar": "--radius-xl", "computed": "calc(var(--radius) + 4px)", "approx": "0.875rem" },
    "2xl":   { "cssVar": "--radius-2xl","computed": "calc(var(--radius) + 8px)", "approx": "1.125rem" },
    "3xl":   { "cssVar": "--radius-3xl","computed": "calc(var(--radius) + 12px)","approx": "1.375rem" },
    "4xl":   { "cssVar": "--radius-4xl","computed": "calc(var(--radius) + 16px)","approx": "1.625rem" }
  },

  "usage": {
    "$description": "How to use these tokens in components",
    "examples": [
      "bg-background text-foreground — page body",
      "bg-card text-card-foreground border border-border rounded-lg — cards",
      "bg-primary text-primary-foreground — primary actions",
      "bg-secondary text-secondary-foreground — secondary actions",
      "bg-muted text-muted-foreground — disabled/subtle surfaces",
      "bg-accent text-accent-foreground — hover states",
      "bg-destructive text-white — danger actions",
      "border-input — form inputs",
      "ring-ring — focus rings",
      "rounded-sm/md/lg/xl/2xl/3xl/4xl — radius scale"
    ]
  }
}
