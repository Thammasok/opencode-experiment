{
  "$schema": "https://tr.designtokens.org/format/",
  "$description": "Border radius and width for SAN.ai. Radius is driven by --radius: 0.625rem (base) in globals.css, with computed variants in @theme inline. Use Tailwind radius utilities: rounded-sm/md/lg/xl/2xl/3xl/4xl.",

  "radius": {
    "$description": "Driven by CSS variable --radius: 0.625rem in :root. Computed via calc() in @theme inline.",
    "cssVarBase": "--radius",
    "baseValue": "0.625rem",

    "scale": {
      "none": { "$value": "0px",       "$type": "dimension", "tailwind": "rounded-none" },
      "sm":   { "$value": "calc(var(--radius) - 4px)", "$type": "dimension", "tailwind": "rounded-sm",  "approx": "0.375rem / 6px"  },
      "md":   { "$value": "calc(var(--radius) - 2px)", "$type": "dimension", "tailwind": "rounded-md",  "approx": "0.5rem / 8px"    },
      "lg":   { "$value": "var(--radius)",              "$type": "dimension", "tailwind": "rounded-lg",  "approx": "0.625rem / 10px" },
      "xl":   { "$value": "calc(var(--radius) + 4px)", "$type": "dimension", "tailwind": "rounded-xl",  "approx": "0.875rem / 14px" },
      "2xl":  { "$value": "calc(var(--radius) + 8px)", "$type": "dimension", "tailwind": "rounded-2xl", "approx": "1.125rem / 18px" },
      "3xl":  { "$value": "calc(var(--radius) + 12px)","$type": "dimension", "tailwind": "rounded-3xl", "approx": "1.375rem / 22px" },
      "4xl":  { "$value": "calc(var(--radius) + 16px)","$type": "dimension", "tailwind": "rounded-4xl", "approx": "1.625rem / 26px" },
      "full": { "$value": "9999px",    "$type": "dimension", "tailwind": "rounded-full" }
    },

    "semantic": {
      "$description": "Component-specific radius recommendations",
      "button":  "rounded-md",
      "input":   "rounded-md",
      "card":    "rounded-lg",
      "badge":   "rounded-md",
      "dialog":  "rounded-lg",
      "sheet":   "rounded-none (edge-attached)",
      "drawer":  "rounded-t-lg (mobile bottom sheet)",
      "tooltip": "rounded-md",
      "avatar":  "rounded-full",
      "tag":     "rounded-full",
      "popover": "rounded-lg"
    }
  },

  "width": {
    "scale": {
      "0": { "$value": "0px", "$type": "dimension" },
      "1": { "$value": "1px", "$type": "dimension" },
      "2": { "$value": "2px", "$type": "dimension" },
      "4": { "$value": "4px", "$type": "dimension" }
    },
    "semantic": {
      "thin":    { "$value": "1px", "tailwind": "border" },
      "default": { "$value": "1px", "tailwind": "border" },
      "medium":  { "$value": "2px", "tailwind": "border-2" },
      "thick":   { "$value": "4px", "tailwind": "border-4" }
    }
  }
}
