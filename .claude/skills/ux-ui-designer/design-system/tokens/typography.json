{
  "$schema": "https://tr.designtokens.org/format/",
  "$description": "Typography system for SAN.ai. Fonts: Geist Sans (sans) + Geist Mono (mono), loaded via next/font/google. Tailwind maps --font-sans and --font-mono via @theme inline in globals.css.",

  "fontFamily": {
    "sans":  { "$value": "var(--font-geist-sans), ui-sans-serif, system-ui, sans-serif", "$type": "fontFamily", "cssVar": "--font-sans", "nextjsFont": "Geist", "subsets": ["latin"] },
    "mono":  { "$value": "var(--font-geist-mono), ui-monospace, 'Courier New', mono",   "$type": "fontFamily", "cssVar": "--font-mono", "nextjsFont": "Geist_Mono", "subsets": ["latin"] },
    "serif": { "$value": "Georgia, ui-serif, serif", "$type": "fontFamily", "$note": "Not used in this project" }
  },

  "fontSize": {
    "$description": "Major Third scale (base 16px, ratio 1.25). Values in rem.",
    "xs":   { "$value": "0.64rem",   "$type": "dimension", "$px": "10.24px" },
    "sm":   { "$value": "0.8rem",    "$type": "dimension", "$px": "12.8px"  },
    "base": { "$value": "1rem",      "$type": "dimension", "$px": "16px"    },
    "lg":   { "$value": "1.25rem",   "$type": "dimension", "$px": "20px"    },
    "xl":   { "$value": "1.563rem",  "$type": "dimension", "$px": "25px"    },
    "2xl":  { "$value": "1.953rem",  "$type": "dimension", "$px": "31.25px" },
    "3xl":  { "$value": "2.441rem",  "$type": "dimension", "$px": "39.06px" },
    "4xl":  { "$value": "3.052rem",  "$type": "dimension", "$px": "48.83px" },
    "5xl":  { "$value": "3.815rem",  "$type": "dimension", "$px": "61.04px" }
  },

  "fontWeight": {
    "normal":   { "$value": "400", "$type": "fontWeight" },
    "medium":   { "$value": "500", "$type": "fontWeight" },
    "semibold": { "$value": "600", "$type": "fontWeight" },
    "bold":     { "$value": "700", "$type": "fontWeight" }
  },

  "lineHeight": {
    "none":    { "$value": "1",     "$type": "number" },
    "tight":   { "$value": "1.25",  "$type": "number" },
    "snug":    { "$value": "1.375", "$type": "number" },
    "normal":  { "$value": "1.5",   "$type": "number" },
    "relaxed": { "$value": "1.625", "$type": "number" },
    "loose":   { "$value": "2",     "$type": "number" }
  },

  "letterSpacing": {
    "tighter": { "$value": "-0.05em",  "$type": "dimension" },
    "tight":   { "$value": "-0.025em", "$type": "dimension" },
    "normal":  { "$value": "0em",      "$type": "dimension" },
    "wide":    { "$value": "0.025em",  "$type": "dimension" },
    "wider":   { "$value": "0.05em",   "$type": "dimension" },
    "widest":  { "$value": "0.1em",    "$type": "dimension" }
  },

  "textStyles": {
    "$description": "Composite text styles. Use Tailwind utility classes directly.",
    "displayLg":  { "tailwind": "text-4xl font-bold tracking-tight leading-tight" },
    "displayMd":  { "tailwind": "text-3xl font-bold tracking-tight leading-tight" },
    "displaySm":  { "tailwind": "text-2xl font-semibold tracking-tight" },
    "heading1":   { "tailwind": "text-xl font-semibold" },
    "heading2":   { "tailwind": "text-lg font-semibold" },
    "heading3":   { "tailwind": "text-base font-semibold" },
    "bodyLg":     { "tailwind": "text-base font-normal" },
    "bodyMd":     { "tailwind": "text-sm font-normal" },
    "bodySm":     { "tailwind": "text-xs font-normal" },
    "labelLg":    { "tailwind": "text-sm font-medium" },
    "labelMd":    { "tailwind": "text-xs font-medium" },
    "mono":       { "tailwind": "font-mono text-sm" }
  }
}
